<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Helpdesk Lite</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<nav class="navbar">
    <a class="navbar-brand" asp-controller="Tickets" asp-action="Index">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 5v2M15 11v2M15 17v2M5 5h14a2 2 0 0 1 2 2v3a2 2 0 0 0 0 4v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-3a2 2 0 0 0 0-4V7a2 2 0 0 1 2-2z"/>
        </svg>
        Helpdesk Lite
    </a>
    <nav class="navbar-nav">
        <a asp-controller="Tickets" asp-action="Index">Tickets</a>
        <a asp-controller="Tickets" asp-action="Create">Novo Ticket</a>
    </nav>
</nav>
<main class="page">
    @RenderBody()
</main>
</body>
</html>
